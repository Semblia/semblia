# Compose/deployment coordinates (non-secret)
SEMBLIA_IMAGE=ghcr.io/semblia/semblia-api:replace-with-commit-sha
API_HOST_PORT=8100
APP_URL=https://app.semblia.com
API_URL=https://api.semblia.com

# API runtime
NODE_ENV=production
API_V2_PORT=8000
API_V2_CORS_ORIGINS=https://app.semblia.com,https://admin.semblia.com
API_V2_RATE_LIMIT_TTL_SECONDS=60
API_V2_RATE_LIMIT_MAX=120
DATABASE_URL=
REDIS_URL=

# Customer Clerk application
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_AUTHORIZED_PARTIES=https://app.semblia.com
CLERK_JWT_AUDIENCE=
CLERK_WEBHOOK_SIGNING_SECRET=

# Separate admin Clerk application
ADMIN_CLERK_SECRET_KEY=
ADMIN_CLERK_PUBLISHABLE_KEY=
ADMIN_CLERK_AUTHORIZED_PARTIES=https://admin.semblia.com
ADMIN_CLERK_JWT_AUDIENCE=

# Razorpay (required by the current production schema; never commit values)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PRO_MONTHLY=
RAZORPAY_PLAN_ID_BUSINESS_MONTHLY=

# Transactional email stays disabled until separately approved.
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=Semblia <notifications@semblia.com>
EMAIL_REPLY_TO=
EMAIL_DAILY_LIMIT=1000
APP_PUBLIC_URL=https://app.semblia.com

# Public forms and encrypted-at-rest application secrets
FORMS_RUNTIME_SIGNING_SECRET=
FORMS_RUNTIME_PUBLIC_BASE_DOMAIN=forms.semblia.com
API_V2_SECRET_ENCRYPTION_KEY=

# Worker limits
WORKER_CONCURRENCY_EMAIL=5
SLACK_WEBHOOK_URL=

# Object storage
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
S3_PUBLIC_CDN_BASE_URL=
S3_PRESIGN_PUT_TTL_SECONDS=600
S3_PRESIGN_GET_TTL_SECONDS=300
S3_MAX_IMAGE_BYTES=8388608
S3_MAX_VIDEO_BYTES=314572800
S3_MAX_EXPORT_BYTES=104857600

# Paid AWS moderation stays disabled until separately approved.
MODERATION_AWS_ENABLED=false
MODERATION_AWS_REGION=us-east-1
MODERATION_AWS_DAILY_BUDGET_CENTS=500
MODERATION_AWS_MONTHLY_BUDGET_CENTS=5000
MODERATION_IMAGE_MIN_CONFIDENCE=70
MODERATION_QUEUE_CONCURRENCY=3
MODERATION_FULL_VIDEO_ENABLED=false
MODERATION_FULL_VIDEO_MIN_PLAN=BUSINESS

